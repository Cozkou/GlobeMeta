# Copy to `.env` for local dev. Restart `npm run dev` after editing (Vite embeds `VITE_*` at build time).
#
# Express API lives in `server/` — start with: cd server && node index.js (default http://localhost:4000).
# If you leave this unset, the app uses same-origin `/api/...` and Vite’s dev proxy (see vite.config.ts).

VITE_API_URL=http://localhost:4000
